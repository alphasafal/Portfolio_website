# Copy to .env.local for local development
# Set all of these in Vercel → Settings → Environment Variables before going live

# Required for contact form delivery (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Where contact form messages are delivered (defaults to safallovetocode@gmail.com)
CONTACT_TO_EMAIL=safallovetocode@gmail.com

# Must be a verified sender in Resend (use your domain after DNS setup)
# For testing only, Resend allows: onboarding@resend.dev
CONTACT_FROM_EMAIL=Safal Gupta <hello@safalgupta.tech>

# Optional — Calendly/booking link (shows "Book a call" in Contact)
NEXT_PUBLIC_CAL_LINK=https://calendly.com/your-link

# Optional — newsletter via Buttondown
BUTTONDOWN_API_KEY=
